{
    "name": "mycelo",
    "productName": "myCelo",
    "version": "2.1.0",
    "description": "COH2/COH3 ranking display",
    "license": "GPL-3.0-or-later",
    "author": "Sergei Polishsuk",
    "engines": {
        "node": ">=18.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/sepi4/myCeloJs/"
    },
    "publish": {
        "provider": "github",
        "releaseType": "release"
    },
    "main": "out/main/index.js",
    "scripts": {
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "test": "jest",
        "coverage": "jest --coverage && xdg-open coverage/index.html",
        "dist": "jest && npm run e2e && electron-builder",
        "dist-win": "jest && npm run e2e && electron-builder --win",
        "e2e": "npm run build && npx playwright test",
        "format": "prettier --write .",
        "prepare": "husky"
    },
    "dependencies": {
        "@fortawesome/fontawesome-svg-core": "^7.2.0",
        "@fortawesome/free-solid-svg-icons": "^7.2.0",
        "@fortawesome/react-fontawesome": "^3.2.0",
        "dayjs": "^1.11.19",
        "portfinder": "^1.0.38",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-modal": "^3.16.3",
        "string-width": "^8.2.0",
        "styled-components": "^6.3.11",
        "use-sound": "^5.0.0",
        "zustand": "^5.0.11"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "prettier --write",
            "eslint --fix --max-warnings 0 --no-warn-ignored"
        ],
        "*.{js,json,css}": "prettier --write"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@playwright/test": "^1.58.2",
        "@types/jest": "^30.0.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/react-modal": "^3.16.3",
        "@types/react-redux": "^7.1.34",
        "@vitejs/plugin-react": "^5.1.4",
        "electron": "^40.8.0",
        "electron-builder": "^26.8.1",
        "electron-vite": "^5.0.0",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jest": "^29.15.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "jest-environment-jsdom": "^30.3.0",
        "lint-staged": "^16.3.3",
        "prettier": "^3.8.1",
        "ts-jest": "^29.4.6",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.0",
        "typescript-plugin-css-modules": "^5.2.0"
    }
}
